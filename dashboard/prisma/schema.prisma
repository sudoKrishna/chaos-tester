// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}


datasource db {
  provider = "postgresql"
}

model UploadedSpec {
  id        String   @id
  filename  String?
  content   String
  createdAt DateTime @default(now())
  report    Report?
}

model Report {
  id             String       @id
  specId         String       @unique
  spec           UploadedSpec @relation(fields: [specId], references: [id])
  baseUrl        String
  totalEndpoints Int
  totalFindings  Int
  findings       Json
  createdAt      DateTime     @default(now())
}